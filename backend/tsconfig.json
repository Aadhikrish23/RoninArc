{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2020",
    /* Paths */
    "rootDir": "./src",
    "outDir": "./dist",
    /* Module Resolution */
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    /* Strictness */
    "strict": true,
    "skipLibCheck": true,
    /* Source Maps */
    "sourceMap": true,
    /* Better Node behavior */
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules"
  ]
}